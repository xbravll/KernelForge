<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="16dp" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tools" android:textColor="@color/primary"
            android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

        <!-- Quick Action Grid -->
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="0"
            android:nestedScrollingEnabled="false">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_drop_caches"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Drop Caches" android:textSize="11sp" android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_force_stop_bg"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Kill BG Apps" android:textSize="11sp" android:layout_marginStart="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_logcat"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Logcat" android:textSize="11sp" android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_wakelock"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Wakelock" android:textSize="11sp" android:layout_marginStart="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_top_procs"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Top Processes" android:textSize="11sp" android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_prop_editor"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Prop Editor" android:textSize="11sp" android:layout_marginStart="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_net_info"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Network Info" android:textSize="11sp" android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_battery_cal"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Batt Calibrate" android:textSize="11sp" android:layout_marginStart="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/accent_yellow" app:cornerRadius="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_reboot_normal"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Reboot" android:textSize="11sp" android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/accent_orange" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_reboot_recovery"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Recovery" android:textSize="11sp" android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_reboot_bootloader"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Bootloader" android:textSize="11sp" android:layout_marginStart="4dp"
                    android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary" app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Terminal -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:padding="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Terminal" android:textColor="@color/primary" android:textSize="13sp" android:textStyle="bold"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_clear_terminal"
                    android:layout_width="wrap_content" android:layout_height="28dp"
                    android:text="Clear" android:textSize="10sp" android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:backgroundTint="@color/bg_surface" android:textColor="@color/text_secondary" app:cornerRadius="8dp"/>
            </LinearLayout>

            <ScrollView android:id="@+id/sv_terminal" android:layout_width="match_parent"
                android:layout_height="0dp" android:layout_weight="1"
                android:background="@color/bg_primary" android:padding="8dp">
                <TextView android:id="@+id/tv_terminal_output"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="# KernelForge Terminal (root)\n"
                    android:textColor="@color/status_good" android:textSize="11sp"
                    android:fontFamily="monospace"/>
            </ScrollView>

            <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                android:orientation="horizontal" android:layout_marginTop="8dp">
                <EditText android:id="@+id/et_terminal_input" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:hint="$ enter command..." android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary" android:textSize="12sp"
                    android:background="@drawable/bg_card_accent" android:paddingStart="12dp"
                    android:fontFamily="monospace" android:inputType="text"
                    android:imeOptions="actionDone"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_run_cmd"
                    android:layout_width="60dp" android:layout_height="match_parent"
                    android:text="Run" android:textSize="12sp" android:layout_marginStart="6dp"
                    android:backgroundTint="@color/primary" android:textColor="@color/bg_primary" app:cornerRadius="10dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
