<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPU Config"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_gpu_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPU"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_card_accent" />
        </LinearLayout>

        <!-- Live Stats: Current / Max / Min -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CURRENT" android:textColor="@color/text_secondary"
                        android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/tv_gpu_freq_current"
                        android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1"
                        android:gravity="center" android:text="—"
                        android:textColor="@color/accent_purple" android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MHz" android:textColor="@color/text_tertiary" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MAX" android:textColor="@color/text_secondary"
                        android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/tv_gpu_max_freq"
                        android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1"
                        android:gravity="center" android:text="—"
                        android:textColor="@color/accent" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MHz" android:textColor="@color/text_tertiary" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MIN" android:textColor="@color/text_secondary"
                        android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/tv_gpu_min_freq"
                        android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1"
                        android:gravity="center" android:text="—"
                        android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MHz" android:textColor="@color/text_tertiary" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Active Governor Strip -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card_elevated" app:cardCornerRadius="14dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ACTIVE GOV" android:textColor="@color/text_tertiary"
                    android:textSize="10sp" android:letterSpacing="0.08"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView android:id="@+id/tv_gpu_gov_current"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/primary"
                    android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- GPU Governor — Chip / Spinner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="20dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="GPU GOVERNOR" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:letterSpacing="0.1" android:textAllCaps="true"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Scaling Policy" android:textColor="@color/text_tertiary" android:textSize="10sp"/>
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_gpu_governor"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:singleSelection="true" app:selectionRequired="true"/>

                <Spinner android:id="@+id/spinner_gpu_governor"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:visibility="gone" android:background="@drawable/bg_card_accent"
                    android:popupBackground="@color/bg_card"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Frequency Limits — SPINNER dari available_frequencies device -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="20dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FREQUENCY LIMITS"
                    android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:letterSpacing="0.1" android:textAllCaps="true"
                    android:layout_marginBottom="16dp"/>

                <!-- Max Frequency Spinner -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Max Frequency"
                        android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_gpu_max_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="from device"
                        android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                </LinearLayout>
                <Spinner android:id="@+id/spinner_gpu_max_freq"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_card_accent"
                    android:popupBackground="@color/bg_card"
                    android:layout_marginBottom="16dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="16dp"/>

                <!-- Min Frequency Spinner -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Min Frequency"
                        android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_gpu_min_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="from device"
                        android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                </LinearLayout>
                <Spinner android:id="@+id/spinner_gpu_min_freq"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_card_accent"
                    android:popupBackground="@color/bg_card"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Advanced Switches -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="20dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ADVANCED" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:letterSpacing="0.1" android:textAllCaps="true"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingTop="4dp" android:paddingBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Adreno Boost" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Force GPU clock on — Snapdragon only"
                            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_adreno_boost" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingTop="4dp" android:paddingBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Thermal Throttling" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Allow GPU to throttle when hot"
                            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_gpu_throttle" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:paddingTop="4dp" android:paddingBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="OC Mode" android:textColor="@color/accent_red" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  ⚠" android:textColor="@color/accent_yellow" android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Force performance governor — may cause heat"
                            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switch_gpu_oc" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Apply Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply_gpu"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Apply GPU Config"
            android:textSize="15sp"
            android:textStyle="bold"
            style="@style/Widget.KernelForge.Button"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
